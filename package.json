{
  "name": "might-be-human",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "build:web": "pnpm --filter @mightbehuman/web run build",
    "build:docs": "pnpm --filter @mightbehuman/docs run build && pnpm --filter @mightbehuman/docs run export",
    "build:desktop": "pnpm --filter @mightbehuman/desktop run build:electron || true",
    "package:all": "pnpm run build:web && pnpm run build:docs && pnpm run build:desktop",
    "dev": "turbo run dev --parallel",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf .turbo dist coverage",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7",
    "electron-builder": "^24.7.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "dependencies": {
    "electron": "^42.2.0",
    "fastify": "^5.8.5",
    "framer-motion": "^12.40.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
